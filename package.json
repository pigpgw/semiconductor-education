{
  "name": "semiconductor-education",
  "version": "0.1.0",
  "private": true,
  "description": "기초부터 실무 관점까지 읽는 반도체 오픈소스 문서 MVP",
  "packageManager": "npm@11.6.2",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "dev": "next dev",
    "start": "next start",
    "build": "next build",
    "check:feed-review": "node scripts/check-feed-review.mjs",
    "check:glossary": "node scripts/check-glossary.mjs",
    "check:industry": "node scripts/check-industry-links.mjs",
    "check:lessons": "node scripts/check-lessons.mjs",
    "check:practice": "node scripts/check-practice.mjs",
    "check:sources": "node scripts/check-sources.mjs",
    "check:viewport": "node scripts/check-viewports.mjs",
    "collect:feeds": "node scripts/collect-source-feeds.mjs",
    "check:content": "npm run check:lessons && npm run check:glossary && npm run check:practice && npm run check:feed-review",
    "check:links": "npm run check:sources && npm run check:industry",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "next typegen && tsc --noEmit",
    "validate": "npm run lint && npm run typecheck && npm run check:content && npm run build"
  },
  "dependencies": {
    "gray-matter": "^4.0.3",
    "lucide-react": "^0.468.0",
    "next": "^16.2.5",
    "next-mdx-remote": "^6.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "remark-gfm": "^4.0.0"
  },
  "devDependencies": {
    "@commitlint/cli": "^20.5.3",
    "@commitlint/config-conventional": "^20.5.3",
    "@eslint/js": "^9.17.0",
    "@next/eslint-plugin-next": "^16.2.5",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.17.0",
    "globals": "^15.14.0",
    "playwright-core": "^1.59.1",
    "postcss": "^8.5.10",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.18.1"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
